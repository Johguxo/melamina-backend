generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  FREELANCER
  BUSINESS
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum DocumentType {
  RUC
  DNI
  OTHER
}

model Tenant {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  accountType AccountType @default(FREELANCER)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       User[]
  clients     Client[]
  staff       Staff[]
  staffRoles  StaffRole[]
}

model StaffRole {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  staff       Staff[]

  @@unique([tenantId, name])
  @@index([tenantId, deletedAt])
}

model Staff {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  firstName      String
  lastName       String
  documentType   DocumentType
  documentNumber String
  phone          String?
  email          String?
  roleId         String?
  role           StaffRole?   @relation(fields: [roleId], references: [id])
  hireDate       DateTime?
  hourlyRate     Decimal?     @db.Decimal(10, 2)
  active         Boolean      @default(true)
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([tenantId, documentNumber])
  @@index([tenantId, deletedAt])
}

model Client {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  name           String
  documentType   DocumentType
  documentNumber String
  phone          String?
  email          String?
  address        String?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([tenantId, documentNumber])
  @@index([tenantId, deletedAt])
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  role      UserRole
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, deletedAt])
}
