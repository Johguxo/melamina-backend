generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  FREELANCER
  BUSINESS
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum DocumentType {
  RUC
  DNI
  OTHER
}

model Tenant {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  accountType AccountType @default(FREELANCER)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       User[]
  clients     Client[]
}

model Client {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  name           String
  documentType   DocumentType
  documentNumber String
  phone          String?
  email          String?
  address        String?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([tenantId, documentNumber])
  @@index([tenantId, deletedAt])
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  role      UserRole
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, deletedAt])
}
